@inherits LayoutComponentBase
@inject ISettingsService SettingsService

<MudThemeProvider @bind-IsDarkMode="SettingsService.Appearance.DarkMode" Theme="_theme" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<MudLayout>
    <MudAppBar Elevation="1" Dense="true">
        <MudText Typo="Typo.h6">YTR</MudText>
        <MudSpacer />
        <MudIconButton Href="/" Icon="@Icons.Material.Filled.Home"
                       Color="Color.Inherit" />
        <MudIconButton Href="/history" Icon="@Icons.Material.Filled.History"
                       Color="Color.Inherit" />
        <MudIconButton Href="/settings" Icon="@Icons.Material.Filled.Settings"
                       Color="Color.Inherit" />
    </MudAppBar>

    <MudMainContent Style="height: calc(100vh - 48px); overflow: hidden; padding: 16px 16px 8px 16px; margin-top: 48px;">
        @Body
    </MudMainContent>
</MudLayout>

@code {
    private readonly MudTheme _theme = new()
    {
        PaletteLight = new PaletteLight
        {
            Primary = "#7c4dff",
            Secondary = "#ff4081",
            AppbarBackground = "#1e1e2e"
        },
        PaletteDark = new PaletteDark
        {
            Primary = "#7c4dff",
            Secondary = "#ff4081",
            Surface = "#1e1e2e",
            Background = "#11111b",
            AppbarBackground = "#181825"
        }
    };
}
