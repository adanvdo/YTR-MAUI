@inherits LayoutComponentBase
@implements IDisposable
@inject ISettingsService SettingsService

<MudThemeProvider @bind-IsDarkMode="SettingsService.Appearance.DarkMode" Theme="_theme" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<MudLayout>
    <MudAppBar Elevation="1" Dense="true">
        <MudImage Src="YTRLogo.png" Alt="YTR" Width="28" Height="28" Class="mr-2" />
        <MudSpacer />
        <MudIconButton Href="/" Icon="@Icons.Material.Filled.Home"
                       Color="Color.Inherit" title="Home" />
        <MudIconButton Href="/history" Icon="@Icons.Material.Filled.History"
                       Color="Color.Inherit" title="History" />
        <MudIconButton Href="/settings" Icon="@Icons.Material.Filled.Settings"
                       Color="Color.Inherit" title="Settings" />
    </MudAppBar>

    <MudMainContent Style="height: calc(100vh - 48px); overflow: hidden; padding: 16px 16px 8px 16px; margin-top: 48px;">
        @Body
    </MudMainContent>
</MudLayout>

@code {
    private readonly MudTheme _theme = new()
    {
        PaletteLight = new PaletteLight
        {
            Primary = "#7c4dff",
            Secondary = "#ff4081",
            AppbarBackground = "#1e1e2e"
        },
        PaletteDark = new PaletteDark
        {
            Primary = "#7c4dff",
            Secondary = "#ff4081",
            Surface = "#1e1e2e",
            Background = "#11111b",
            AppbarBackground = "#181825"
        }
    };

    protected override void OnInitialized()
    {
        SettingsService.DarkModeChanged += OnDarkModeChanged;
    }

    private void OnDarkModeChanged()
    {
        InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        SettingsService.DarkModeChanged -= OnDarkModeChanged;
    }
}
