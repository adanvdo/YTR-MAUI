@inherits LayoutComponentBase

<MudThemeProvider @bind-IsDarkMode="_isDarkMode" Theme="_theme" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<MudLayout>
    <MudAppBar Elevation="1" Dense="true">
        <MudText Typo="Typo.h6">YTR</MudText>
        <MudSpacer />
        <MudIconButton Href="/" Icon="@Icons.Material.Filled.Home"
                       Color="Color.Inherit" />
        <MudIconButton Href="/history" Icon="@Icons.Material.Filled.History"
                       Color="Color.Inherit" />
        <MudIconButton Href="/settings" Icon="@Icons.Material.Filled.Settings"
                       Color="Color.Inherit" />
        <MudIconButton Href="/updates" Icon="@Icons.Material.Filled.SystemUpdateAlt"
                       Color="Color.Inherit" />
        <MudIconButton Icon="@(_isDarkMode ? Icons.Material.Filled.LightMode : Icons.Material.Filled.DarkMode)"
                       Color="Color.Inherit" OnClick="@ToggleTheme" />
    </MudAppBar>

    <MudMainContent Style="height: calc(100vh - 48px); overflow: hidden; padding: 16px; margin-top: 48px;">
        @Body
    </MudMainContent>
</MudLayout>

@code {
    private bool _isDarkMode = true;

    private readonly MudTheme _theme = new()
    {
        PaletteLight = new PaletteLight
        {
            Primary = "#7c4dff",
            Secondary = "#ff4081",
            AppbarBackground = "#1e1e2e"
        },
        PaletteDark = new PaletteDark
        {
            Primary = "#7c4dff",
            Secondary = "#ff4081",
            Surface = "#1e1e2e",
            Background = "#11111b",
            AppbarBackground = "#181825"
        }
    };

    private void ToggleTheme() => _isDarkMode = !_isDarkMode;
}
