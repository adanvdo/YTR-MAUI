@page "/"
@inject IYtDlpService YtDlp
@inject IDownloadOrchestrator Orchestrator
@inject IUrlAnalyzer UrlAnalyzer
@inject ISettingsService Settings
@inject IPlatformService Platform
@inject DownloadStateService State

<PageTitle>YTR - Home</PageTitle>

<div class="home-layout">
    <div class="home-content">
        <div class="home-main">
            <div class="home-fixed-top">
                <InputPanel OnUrlAnalyzed="OnUrlAnalyzed" IsLoading="_loadingFormats" />
                <VideoInfoPanel Class="mt-2" Metadata="_metadata" />
            </div>

            <div class="home-scrollable">
                @if (_metadata?.IsPlaylist == true && _metadata.PlaylistItems is not null)
                {
                    <PlaylistGrid Class="mt-2" Items="_metadata.PlaylistItems"
                                  SelectionChanged="OnPlaylistSelectionChanged" />
                }
                else
                {
                    <FormatGrid Class="mt-2" Formats="_formats"
                                FormatPairSelected="OnFormatPairSelected"
                                FormatSelected="OnFormatSelected" />
                }
            </div>
        </div>

        <div class="home-sidebar">
            <ControlPanel OnDownloadVideo="DownloadVideo"
                          OnDownloadAudio="DownloadAudio"
                          OnDownloadBest="DownloadBest"
                          Disabled="_downloading"
                          ShowDownloadSelected="_hasFormatSelection"
                          SelectedPair="_selectedPair"
                          ThumbnailUrl="@(_metadata?.ThumbnailUrl)"
                          IsPlaylist="@(_metadata?.IsPlaylist == true)" />
        </div>
    </div>

    <div class="home-status">
        <StatusBar ShowIndeterminate="_loadingFormats" />
    </div>
</div>

@code {
    private MediaMetadata? _metadata;
    private IReadOnlyList<FormatInfo>? _formats;
    private FormatPair? _selectedPair;
    private FormatInfo? _selectedFormat;
    private IReadOnlyList<PlaylistItem>? _selectedPlaylistItems;
    private bool _downloading;
    private bool _loadingFormats;
    private bool _hasFormatSelection;

    private async Task OnUrlAnalyzed(UrlAnalysisResult analysis)
    {
        if (!analysis.IsValid) return;

        State.UpdateStatus("Fetching formats...");
        _metadata = null;
        _formats = null;
        _selectedPair = null;
        _selectedFormat = null;
        _hasFormatSelection = false;
        _loadingFormats = true;
        StateHasChanged();

        var result = analysis.IsPlaylist
            ? await YtDlp.GetPlaylistInfoAsync(analysis.NormalizedUrl)
            : await YtDlp.GetMediaInfoAsync(analysis.NormalizedUrl);

        if (result.IsSuccess && result.Value is not null)
        {
            _metadata = result.Value;
            _formats = result.Value.Formats;
            State.UpdateStatus($"Found {_formats.Count} formats.");
        }
        else
        {
            State.UpdateStatus($"Error: {result.Error}");
        }
        _loadingFormats = false;
        StateHasChanged();
    }

    private void OnFormatPairSelected(FormatPair pair)
    {
        _selectedPair = pair;
        _hasFormatSelection = pair.IsValid;
        StateHasChanged();
    }

    private void OnFormatSelected(FormatInfo? format)
    {
        _selectedFormat = format;
    }

    private void OnPlaylistSelectionChanged(IReadOnlyList<PlaylistItem> items)
    {
        _selectedPlaylistItems = items;
    }

    private async Task DownloadVideo(DownloadRequest request) => await ExecuteDownload(StreamKind.Video, request);
    private async Task DownloadAudio(DownloadRequest request) => await ExecuteDownload(StreamKind.Audio, request);
    private async Task DownloadBest(DownloadRequest request) => await ExecuteDownload(StreamKind.AudioAndVideo, request);

    private async Task ExecuteDownload(StreamKind streamKind, DownloadRequest request)
    {
        if (_metadata is null) return;

        _downloading = true;
        StateHasChanged();

        var ct = State.StartOperation();
        var progress = new Progress<DownloadProgress>(p =>
        {
            State.UpdateProgress(p);
            InvokeAsync(StateHasChanged);
        });
        var output = new Progress<string>(msg => State.UpdateStatus(msg));

        try
        {
            if (_metadata.IsPlaylist && _metadata.PlaylistItems is not null)
            {
                var items = _selectedPlaylistItems ?? _metadata.PlaylistItems;
                var playlistProgress = new Progress<PlaylistProgress>(p =>
                {
                    State.UpdatePlaylistProgress(p.Completed, p.Total);
                    InvokeAsync(StateHasChanged);
                });

                var playlistRequest = request with { PlaylistFolder = _metadata.Title?.Replace(" ", "") ?? "Playlist" };
                var result = await Orchestrator.DownloadPlaylistAsync(
                    _metadata.Url, items, streamKind, playlistRequest, progress, output, playlistProgress, ct);

                State.ResetPlaylist();
                if (result.IsSuccess)
                    State.UpdateStatus($"Playlist complete: {result.Value} items downloaded.");
                else
                    State.UpdateStatus($"Failed: {result.Error}");
            }
            else if (_selectedPair is not null && _selectedPair.IsValid)
            {
                var result = await Orchestrator.DownloadFormatAsync(_metadata.Url, _selectedPair, request, progress, output, ct);
                HandleResult(result);
            }
            else
            {
                var result = await Orchestrator.DownloadBestAsync(_metadata.Url, streamKind, request, progress, output, ct);
                HandleResult(result);
            }
        }
        catch (OperationCanceledException)
        {
            State.UpdateStatus("Download cancelled.");
        }
        catch (Exception ex)
        {
            State.UpdateStatus($"Error: {ex.Message}");
        }
        finally
        {
            _downloading = false;
            State.Reset();
            StateHasChanged();
        }
    }

    private void HandleResult(Result<DownloadRecord> result)
    {
        if (result.IsSuccess)
        {
            State.UpdateStatus($"Complete: {result.Value!.Title}");
            if (Settings.Download.AutoOpenDownloadLocation)
            {
                _ = Platform.OpenFolderAsync(result.Value.FilePath);
            }
        }
        else
        {
            State.UpdateStatus($"Failed: {result.Error}");
        }
    }
}
