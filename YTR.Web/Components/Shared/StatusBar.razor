@inject DownloadStateService State
@implements IDisposable

<div class="status-bar">
    @if (State.IsDownloading)
    {
        @if (State.CurrentProgress.Progress > 0)
        {
            <MudProgressLinear Value="@(State.CurrentProgress.Progress * 100)" Color="Color.Primary"
                               Rounded="true" Size="Size.Small" Class="status-progress" />
        }
        else
        {
            <MudProgressLinear Indeterminate="true" Color="Color.Primary"
                               Rounded="true" Size="Size.Small" Class="status-progress" />
        }
                           
        <div class="status-text">
            <span>@State.StatusMessage</span>
            @if (State.CurrentProgress.Speed is not null)
            {
                <span> — @State.CurrentProgress.Speed</span>
            }
            @if (State.CurrentProgress.Eta is not null)
            {
                <span> (ETA: @State.CurrentProgress.Eta)</span>
            }
        </div>
    }
    else if (_indeterminate)
    {
        <MudProgressLinear Indeterminate="true" Color="Color.Primary"
                           Rounded="true" Size="Size.Small" Class="status-progress" />
        <div class="status-text">
            <span>@State.StatusMessage</span>
        </div>
    }
    else
    {
        <div class="status-text">
            <span>@State.StatusMessage</span>
        </div>
    }
</div>

@code {
    private bool _indeterminate;

    [Parameter] public bool ShowIndeterminate { get; set; }

    protected override void OnInitialized()
    {
        State.OnStateChanged += OnStateChanged;
    }

    protected override void OnParametersSet()
    {
        _indeterminate = ShowIndeterminate;
    }

    private void OnStateChanged()
    {
        InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        State.OnStateChanged -= OnStateChanged;
    }
}
