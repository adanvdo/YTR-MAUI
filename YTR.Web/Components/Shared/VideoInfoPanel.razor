<MudPaper Class="pa-4" Elevation="1">
    @if (Metadata is not null)
    {
        <MudGrid>
            @if (!string.IsNullOrEmpty(Metadata.ThumbnailUrl))
            {
                <MudItem xs="12" sm="4">
                    <MudImage Src="@Metadata.ThumbnailUrl" Alt="Thumbnail"
                              ObjectFit="ObjectFit.Cover" Class="rounded" Style="width:100%;" />
                </MudItem>
            }
            <MudItem xs="12" sm="@(string.IsNullOrEmpty(Metadata.ThumbnailUrl) ? 12 : 8)">
                <MudText Typo="Typo.h6">@Metadata.Title</MudText>
                @if (Metadata.Duration.HasValue)
                {
                    <MudText Typo="Typo.body2" Color="Color.Secondary">
                        Duration: @Metadata.Duration.Value.ToString(@"hh\:mm\:ss")
                    </MudText>
                }
                @if (!string.IsNullOrEmpty(Metadata.Uploader))
                {
                    <MudText Typo="Typo.body2">@Metadata.Uploader</MudText>
                }
                @if (!string.IsNullOrEmpty(Metadata.Description))
                {
                    <MudText Typo="Typo.body2" Class="mt-2" Style="max-height:100px;overflow:auto;">
                        @Metadata.Description
                    </MudText>
                }
            </MudItem>
        </MudGrid>
    }
    else
    {
        <MudText Typo="Typo.body2" Color="Color.Tertiary" Align="Align.Center">
            Enter a URL and click "List Formats" to get started.
        </MudText>
    }
</MudPaper>

@code {
    [Parameter] public MediaMetadata? Metadata { get; set; }
}
