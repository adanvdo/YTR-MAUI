@using YTR.Core.Services

<MudPaper Class="pa-4" Elevation="1">
    <MudText Typo="Typo.subtitle1" Class="mb-3">Download Options</MudText>

    <MudStack Spacing="3">
        <MudExpansionPanels>
            <MudExpansionPanel Text="Segment" Expanded="false">
                <MudStack Spacing="2">
                    <MudTimePicker @bind-Time="_segmentStart" Label="Start Time" />
                    <MudTimePicker @bind-Time="_segmentDuration" Label="Duration" />
                </MudStack>
            </MudExpansionPanel>

            <MudExpansionPanel Text="Crop" Expanded="false">
                <MudGrid>
                    <MudItem xs="6"><MudNumericField @bind-Value="_cropTop" Label="Top" /></MudItem>
                    <MudItem xs="6"><MudNumericField @bind-Value="_cropBottom" Label="Bottom" /></MudItem>
                    <MudItem xs="6"><MudNumericField @bind-Value="_cropLeft" Label="Left" /></MudItem>
                    <MudItem xs="6"><MudNumericField @bind-Value="_cropRight" Label="Right" /></MudItem>
                </MudGrid>
            </MudExpansionPanel>

            <MudExpansionPanel Text="Convert" Expanded="false">
                <MudStack Spacing="2">
                    <MudSelect @bind-Value="_convertVideo" Label="Video Format" Variant="Variant.Outlined">
                        <MudSelectItem Value="VideoFormat.Unspecified">None</MudSelectItem>
                        <MudSelectItem Value="VideoFormat.Mp4">MP4</MudSelectItem>
                        <MudSelectItem Value="VideoFormat.Mkv">MKV</MudSelectItem>
                        <MudSelectItem Value="VideoFormat.Webm">WebM</MudSelectItem>
                        <MudSelectItem Value="VideoFormat.Gif">GIF</MudSelectItem>
                    </MudSelect>
                    <MudSelect @bind-Value="_convertAudio" Label="Audio Format" Variant="Variant.Outlined">
                        <MudSelectItem Value="AudioFormat.Unspecified">None</MudSelectItem>
                        <MudSelectItem Value="AudioFormat.Mp3">MP3</MudSelectItem>
                        <MudSelectItem Value="AudioFormat.Aac">AAC</MudSelectItem>
                        <MudSelectItem Value="AudioFormat.Flac">FLAC</MudSelectItem>
                        <MudSelectItem Value="AudioFormat.Opus">Opus</MudSelectItem>
                    </MudSelect>
                </MudStack>
            </MudExpansionPanel>
        </MudExpansionPanels>

        <MudDivider Class="my-2" />

        <MudButton Variant="Variant.Filled" Color="Color.Primary" FullWidth="true"
                   StartIcon="@Icons.Material.Filled.VideoFile"
                   Disabled="Disabled" OnClick="OnClickDownloadVideo">
            Download Video
        </MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Secondary" FullWidth="true"
                   StartIcon="@Icons.Material.Filled.AudioFile"
                   Disabled="Disabled" OnClick="OnClickDownloadAudio">
            Download Audio
        </MudButton>
        <MudButton Variant="Variant.Outlined" Color="Color.Primary" FullWidth="true"
                   StartIcon="@Icons.Material.Filled.Star"
                   Disabled="Disabled" OnClick="OnClickDownloadBest">
            Download Best
        </MudButton>
    </MudStack>
</MudPaper>

@code {
    private TimeSpan? _segmentStart;
    private TimeSpan? _segmentDuration;
    private int _cropTop, _cropBottom, _cropLeft, _cropRight;
    private VideoFormat _convertVideo = VideoFormat.Unspecified;
    private AudioFormat _convertAudio = AudioFormat.Unspecified;

    [Parameter] public bool Disabled { get; set; }
    [Parameter] public EventCallback<DownloadRequest> OnDownloadVideo { get; set; }
    [Parameter] public EventCallback<DownloadRequest> OnDownloadAudio { get; set; }
    [Parameter] public EventCallback<DownloadRequest> OnDownloadBest { get; set; }

    private DownloadRequest BuildRequest()
    {
        int[]? crops = null;
        if (_cropTop > 0 || _cropBottom > 0 || _cropLeft > 0 || _cropRight > 0)
            crops = [_cropLeft, _cropTop, _cropRight - _cropLeft, _cropBottom - _cropTop];

        return new DownloadRequest
        {
            SegmentStart = _segmentStart,
            SegmentDuration = _segmentDuration,
            CropValues = crops,
            ConvertVideo = _convertVideo != VideoFormat.Unspecified ? _convertVideo : null,
            ConvertAudio = _convertAudio != AudioFormat.Unspecified ? _convertAudio : null
        };
    }

    private async Task OnClickDownloadVideo() => await OnDownloadVideo.InvokeAsync(BuildRequest());
    private async Task OnClickDownloadAudio() => await OnDownloadAudio.InvokeAsync(BuildRequest());
    private async Task OnClickDownloadBest() => await OnDownloadBest.InvokeAsync(BuildRequest());
}
