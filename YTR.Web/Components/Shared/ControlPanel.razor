@using YTR.Core.Services
@inject DownloadStateService State
@inject ISettingsService Settings
@inject IDialogService DialogService
@inject IJSRuntime JS
@implements IDisposable

<MudPaper Class="pa-2 control-panel" Elevation="1">
    <MudText Typo="Typo.caption" Class="mb-1 cp-title">Download Options</MudText>

    <MudStack Spacing="1">
        @* Selected format details display *@
        @if (SelectedPair is not null && SelectedPair.IsValid)
        {
            <MudPaper Class="pa-1 px-2 cp-format-display" Elevation="0">
                <MudText Typo="Typo.caption" Class="cp-format-text">
                    @FormatSelectionText
                </MudText>
            </MudPaper>
        }

        @if (!IsPlaylist)
        {
            <MudExpansionPanels MultiExpansion="true" Dense="true">
                @* Segment panel *@
                <MudExpansionPanel @bind-Expanded="_segmentExpanded" Dense="true">
                    <TitleContent>
                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                            <MudText Typo="Typo.body2">Segment</MudText>
                            @if (!_segmentExpanded && _segmentEnabled && SegmentHasValues)
                            {
                                <MudIcon Icon="@Icons.Material.Filled.Circle" Size="Size.Small" Color="Color.Primary" />
                                <MudText Typo="Typo.caption" Color="Color.Primary">@SegmentSummary</MudText>
                            }
                        </MudStack>
                    </TitleContent>
                    <ChildContent>
                        <MudStack Spacing="1" Class="cp-panel-segment">
                            <MudSwitch @bind-Value="_segmentEnabled" Label="Enable" Color="Color.Primary"
                                       Size="Size.Small" Class="cp-toggle" />
                            <TimeSpanPicker Value="_segmentStart" ValueChanged="OnSegmentStartChanged"
                                           Label="Start" Disabled="!_segmentEnabled" />
                            <TimeSpanPicker Value="_segmentEnd" ValueChanged="OnSegmentEndChanged"
                                           Disabled="!_segmentEnabled"
                                           Label="@(_segmentEndMode == SegmentMode.Duration ? "Duration" : "End Time")" />
                        </MudStack>
                    </ChildContent>
                </MudExpansionPanel>

                @* Crop panel *@
                <MudExpansionPanel @bind-Expanded="_cropExpanded" Dense="true">
                    <TitleContent>
                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                            <MudText Typo="Typo.body2">Crop</MudText>
                            @if (!_cropExpanded && _cropEnabled && CropHasValues)
                            {
                                <MudIcon Icon="@Icons.Material.Filled.Circle" Size="Size.Small" Color="Color.Primary" />
                                <MudText Typo="Typo.caption" Color="Color.Primary">@CropSummary</MudText>
                            }
                        </MudStack>
                    </TitleContent>
                    <ChildContent>
                        <MudStack Spacing="1" Class="cp-panel-crop">
                            <MudSwitch @bind-Value="_cropEnabled" Label="Enable" Color="Color.Primary"
                                       Size="Size.Small" Class="cp-toggle" />
                            @if (SelectedPair?.VideoFormat is not null && !string.IsNullOrEmpty(_thumbnailUrl))
                            {
                                <MudButton Variant="Variant.Outlined" Size="Size.Small" FullWidth="true"
                                           StartIcon="@Icons.Material.Filled.Crop" OnClick="OpenCropTool"
                                           Disabled="!_cropEnabled">
                                    Visual Crop Tool
                                </MudButton>
                            }
                            <MudGrid Spacing="1">
                                <MudItem xs="6"><MudNumericField @bind-Value="_cropTop" Label="Top" Min="0" Margin="Margin.Dense" Placeholder="0" Disabled="!_cropEnabled" @onfocus="SelectAllText" /></MudItem>
                                <MudItem xs="6"><MudNumericField @bind-Value="_cropBottom" Label="Bottom" Min="0" Margin="Margin.Dense" Placeholder="0" Disabled="!_cropEnabled" @onfocus="SelectAllText" /></MudItem>
                                <MudItem xs="6"><MudNumericField @bind-Value="_cropLeft" Label="Left" Min="0" Margin="Margin.Dense" Placeholder="0" Disabled="!_cropEnabled" @onfocus="SelectAllText" /></MudItem>
                                <MudItem xs="6"><MudNumericField @bind-Value="_cropRight" Label="Right" Min="0" Margin="Margin.Dense" Placeholder="0" Disabled="!_cropEnabled" @onfocus="SelectAllText" /></MudItem>
                            </MudGrid>
                        </MudStack>
                    </ChildContent>
                </MudExpansionPanel>

                @* Convert panel *@
                <MudExpansionPanel @bind-Expanded="_convertExpanded" Dense="true"
                                  Style="@(_convertFlashing && _convertExpanded ? "animation: flash-border 0.5s ease-in-out 3; border: 2px solid transparent; border-radius: 4px;" : "")">
                    <TitleContent>
                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                            <MudText Typo="Typo.body2">Convert</MudText>
                            @if (!_convertExpanded && ConvertHasValues)
                            {
                                @if (_convertFlashing)
                                {
                                    <MudIcon Icon="@Icons.Material.Filled.Circle" Size="Size.Small"
                                             Style="@($"color: var(--mud-palette-{ConvertColorVar}); animation: flash-to-red 0.5s ease-in-out 3 forwards;")" />
                                    <MudText Typo="Typo.caption"
                                             Style="@($"color: var(--mud-palette-{ConvertColorVar}); animation: flash-to-red 0.5s ease-in-out 3 forwards;")">@ConvertSummary</MudText>
                                }
                                else
                                {
                                    <MudIcon Icon="@Icons.Material.Filled.Circle" Size="Size.Small"
                                             Color="@(ConvertIndicatorColor)" />
                                    <MudText Typo="Typo.caption"
                                             Color="@(ConvertIndicatorColor)">@ConvertSummary</MudText>
                                }
                            }
                            @if (_convertFlashing && _convertExpanded)
                            {
                                <MudIcon Icon="@Icons.Material.Filled.Circle" Size="Size.Small" Color="Color.Error"
                                         Style="animation: blink-warning 0.5s ease-in-out 3;" />
                                <MudText Typo="Typo.caption" Color="Color.Error">will apply to current url</MudText>
                            }
                            @if (_convertWarned && _convertExpanded && !_convertFlashing)
                            {
                                <MudIcon Icon="@Icons.Material.Filled.Circle" Size="Size.Small" Color="Color.Error" />
                                <MudText Typo="Typo.caption" Color="Color.Error">will apply to current url</MudText>
                            }
                        </MudStack>
                    </TitleContent>
                    <ChildContent>
                        <MudStack Spacing="1" Class="cp-panel-convert">
                            @if (_alwaysConvert)
                            {
                                <MudText Typo="Typo.caption" Color="Color.Warning">
                                    Locked to preferred formats (Settings)
                                </MudText>
                            }
                            <MudSelect @bind-Value="_convertVideo" @bind-Value:after="OnConvertValueChanged"
                                       Label="Video" Variant="Variant.Outlined"
                                       Disabled="_alwaysConvert" Margin="Margin.Dense"
                                       Class="@(_convertWarned && _convertVideo != VideoFormat.Unspecified ? "cp-highlight" : "")">
                                <MudSelectItem Value="VideoFormat.Unspecified">None</MudSelectItem>
                                <MudSelectItem Value="VideoFormat.Mp4">MP4</MudSelectItem>
                                <MudSelectItem Value="VideoFormat.Mkv">MKV</MudSelectItem>
                                <MudSelectItem Value="VideoFormat.Webm">WebM</MudSelectItem>
                                <MudSelectItem Value="VideoFormat.Gif">GIF</MudSelectItem>
                            </MudSelect>
                            <MudSelect @bind-Value="_convertAudio" @bind-Value:after="OnConvertValueChanged"
                                       Label="Audio" Variant="Variant.Outlined"
                                       Disabled="_alwaysConvert" Margin="Margin.Dense"
                                       Class="@(_convertWarned && _convertAudio != AudioFormat.Unspecified ? "cp-highlight" : "")">
                                <MudSelectItem Value="AudioFormat.Unspecified">None</MudSelectItem>
                                <MudSelectItem Value="AudioFormat.Mp3">MP3</MudSelectItem>
                                <MudSelectItem Value="AudioFormat.Aac">AAC</MudSelectItem>
                                <MudSelectItem Value="AudioFormat.Flac">FLAC</MudSelectItem>
                                <MudSelectItem Value="AudioFormat.Opus">Opus</MudSelectItem>
                            </MudSelect>
                        </MudStack>
                    </ChildContent>
                </MudExpansionPanel>

                @* Limits panel *@
                <MudExpansionPanel @bind-Expanded="_limitsExpanded" Dense="true"
                                  Style="@(_limitsFlashing && _limitsExpanded ? "animation: flash-border 0.5s ease-in-out 3; border: 2px solid transparent; border-radius: 4px;" : "")">
                    <TitleContent>
                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                            <MudText Typo="Typo.body2">Limits</MudText>
                            @if (!_limitsExpanded && LimitsHasValues)
                            {
                                @if (_limitsFlashing)
                                {
                                    <MudIcon Icon="@Icons.Material.Filled.Circle" Size="Size.Small"
                                             Style="@($"color: var(--mud-palette-{LimitsColorVar}); animation: flash-to-red 0.5s ease-in-out 3 forwards;")" />
                                    <MudText Typo="Typo.caption"
                                             Style="@($"color: var(--mud-palette-{LimitsColorVar}); animation: flash-to-red 0.5s ease-in-out 3 forwards;")">@LimitsSummary</MudText>
                                }
                                else
                                {
                                    <MudIcon Icon="@Icons.Material.Filled.Circle" Size="Size.Small"
                                             Color="@(LimitsIndicatorColor)" />
                                    <MudText Typo="Typo.caption"
                                             Color="@(LimitsIndicatorColor)">@LimitsSummary</MudText>
                                }
                            }
                            @if (_limitsFlashing && _limitsExpanded)
                            {
                                <MudIcon Icon="@Icons.Material.Filled.Circle" Size="Size.Small" Color="Color.Error"
                                         Style="animation: blink-warning 0.5s ease-in-out 3;" />
                                <MudText Typo="Typo.caption" Color="Color.Error">will apply to current url</MudText>
                            }
                            @if (_limitsWarned && _limitsExpanded && !_limitsFlashing)
                            {
                                <MudIcon Icon="@Icons.Material.Filled.Circle" Size="Size.Small" Color="Color.Error" />
                                <MudText Typo="Typo.caption" Color="Color.Error">will apply to current url</MudText>
                            }
                        </MudStack>
                    </TitleContent>
                    <ChildContent>
                        <MudStack Spacing="1" Class="cp-panel-limits">
                            @if (_limitsLocked)
                            {
                                <MudText Typo="Typo.caption" Color="Color.Warning">
                                    Locked to enforced restrictions (Settings)
                                </MudText>
                            }
                            @if (ShowDownloadSelected)
                            {
                                <MudText Typo="Typo.caption" Color="Color.Tertiary">
                                    Disabled — using selected format
                                </MudText>
                            }
                            <MudSelect @bind-Value="_maxResolution" @bind-Value:after="OnLimitsValueChanged"
                                       Label="Max Resolution" Variant="Variant.Outlined"
                                       Margin="Margin.Dense" Disabled="ShowDownloadSelected || _limitsLocked"
                                       Class="@(_limitsWarned && _maxResolution != Resolution.Any ? "cp-highlight" : "")">
                                @foreach (var res in Enum.GetValues<Resolution>())
                                {
                                    <MudSelectItem Value="res">@res</MudSelectItem>
                                }
                            </MudSelect>
                            <MudNumericField @bind-Value="_maxFileSize" @bind-Value:after="OnLimitsValueChanged"
                                             Label="Max Size (MB, 0 = no limit)"
                                             Variant="Variant.Outlined" Min="0" Margin="Margin.Dense"
                                             Disabled="ShowDownloadSelected || _limitsLocked" @onfocus="SelectAllText"
                                             Class="@(_limitsWarned && _maxFileSize > 0 ? "cp-highlight" : "")" />
                        </MudStack>
                    </ChildContent>
                </MudExpansionPanel>
            </MudExpansionPanels>
        }

        <MudDivider Class="my-0" />

        @if (ShowDownloadSelected)
        {
            <MudButton Variant="Variant.Filled" Color="Color.Primary" FullWidth="true"
                       StartIcon="@Icons.Material.Filled.Download" Size="Size.Small"
                       Disabled="Disabled" OnClick="OnClickDownloadVideo">
                Download Selected Format
            </MudButton>
        }
        else
        {
            <MudButton Variant="Variant.Outlined" Color="Color.Primary" FullWidth="true"
                       StartIcon="@Icons.Material.Filled.Star" Size="Size.Small"
                       Disabled="Disabled" OnClick="OnClickDownloadBest">
                @(IsPlaylist ? "Download All [video+audio]" : "Download Best")
            </MudButton>
            <MudButton Variant="Variant.Outlined" Color="Color.Secondary" FullWidth="true"
                       StartIcon="@Icons.Material.Filled.AudioFile" Size="Size.Small"
                       Disabled="Disabled" OnClick="OnClickDownloadAudio">
                @(IsPlaylist ? "Download All Audio" : "Download Audio")
            </MudButton>
        }

        @if (State.CanCancel)
        {            
            <MudButton Variant="Variant.Filled" FullWidth="true"
                        StartIcon="@Icons.Material.Filled.Cancel" Color="Color.Error"
                        Size="Size.Small" OnClick="State.Cancel" 
                        Class="status-cancel">
                        Cancel Download
            </MudButton>
        }
    </MudStack>
</MudPaper>

@code {
    // Segment
    private TimeSpan? _segmentStart;
    private TimeSpan? _segmentEnd;
    private SegmentMode _segmentEndMode;
    private bool _segmentExpanded;
    private bool _segmentEnabled;

    // Crop
    private int? _cropTop, _cropBottom, _cropLeft, _cropRight;
    private bool _cropExpanded;
    private bool _cropEnabled;

    // Convert
    private VideoFormat _convertVideo = VideoFormat.Unspecified;
    private AudioFormat _convertAudio = AudioFormat.Unspecified;
    private bool _convertExpanded;
    private bool _alwaysConvert;
    private bool _convertFlashing;

    // Limits
    private Resolution _maxResolution = Resolution.Any;
    private int _maxFileSize;
    private bool _limitsExpanded;
    private bool _limitsLocked;
    private bool _limitsFlashing;

    // After flashing ends, circle/text stay red until next action
    private bool _convertWarned;
    private bool _limitsWarned;

    private Color ConvertIndicatorColor =>
        _convertWarned ? Color.Error : (_alwaysConvert ? Color.Warning : Color.Primary);

    private Color LimitsIndicatorColor =>
        _limitsWarned ? Color.Error : (_limitsLocked ? Color.Warning : Color.Primary);

    // CSS variable names for use in inline styles during flash animation
    private string ConvertColorVar => _alwaysConvert ? "warning" : "primary";
    private string LimitsColorVar => _limitsLocked ? "warning" : "primary";

    [Parameter] public bool Disabled { get; set; }
    [Parameter] public bool ShowDownloadSelected { get; set; }
    [Parameter] public bool IsPlaylist { get; set; }
    [Parameter] public FormatPair? SelectedPair { get; set; }
    [Parameter] public string? ThumbnailUrl { get; set; }
    [Parameter] public TimeSpan? MediaDuration { get; set; }
    [Parameter] public EventCallback<DownloadRequest> OnDownloadVideo { get; set; }
    [Parameter] public EventCallback<DownloadRequest> OnDownloadAudio { get; set; }
    [Parameter] public EventCallback<DownloadRequest> OnDownloadBest { get; set; }
    [Parameter] public EventCallback<bool> HasOptionsChanged { get; set; }

    /// <summary>
    /// The currently configured max resolution in pixels (0 = no limit).
    /// </summary>
    public int ActiveMaxResolutionPixels => _maxResolution switch
    {
        Resolution.Sd => 480,
        Resolution.Hd720 => 720,
        Resolution.Hd1080 => 1080,
        Resolution.Uhd2160 => 2160,
        _ => 0
    };

    /// <summary>
    /// The currently configured max file size in MB (0 = no limit).
    /// </summary>
    public int ActiveMaxFileSizeMb => _maxFileSize;

    private string? _thumbnailUrl => ThumbnailUrl;

    // Active indicators — only show when the panel is enabled
    private bool SegmentHasValues => _segmentEnabled && (_segmentStart.HasValue || _segmentEnd.HasValue);
    private bool CropHasValues => _cropEnabled && ((_cropTop ?? 0) > 0 || (_cropBottom ?? 0) > 0 || (_cropLeft ?? 0) > 0 || (_cropRight ?? 0) > 0);
    private bool ConvertHasValues => _convertVideo != VideoFormat.Unspecified || _convertAudio != AudioFormat.Unspecified;
    private bool LimitsHasValues => _maxResolution != Resolution.Any || _maxFileSize > 0;

    // Collapsed panel summaries
    private string SegmentSummary
    {
        get
        {
            var start = _segmentStart?.ToString(@"h\:mm\:ss") ?? "0:00:00";
            if (_segmentEnd.HasValue)
            {
                var endLabel = _segmentEndMode == SegmentMode.Duration ? "+" : "→";
                return $"{start} {endLabel} {_segmentEnd.Value:h\\:mm\\:ss}";
            }
            return $"{start} → end";
        }
    }

    private string CropSummary
    {
        get
        {
            var parts = new List<string>();
            if ((_cropTop ?? 0) > 0) parts.Add($"T:{_cropTop}");
            if ((_cropBottom ?? 0) > 0) parts.Add($"B:{_cropBottom}");
            if ((_cropLeft ?? 0) > 0) parts.Add($"L:{_cropLeft}");
            if ((_cropRight ?? 0) > 0) parts.Add($"R:{_cropRight}");
            return string.Join(" ", parts);
        }
    }

    private string ConvertSummary
    {
        get
        {
            if (_alwaysConvert)
                return $"Locked to {_convertVideo} / {_convertAudio}";

            var parts = new List<string>();
            if (_convertVideo != VideoFormat.Unspecified) parts.Add(_convertVideo.ToString());
            if (_convertAudio != AudioFormat.Unspecified) parts.Add(_convertAudio.ToString());
            return string.Join(" / ", parts);
        }
    }

    private string LimitsSummary
    {
        get
        {
            if (_limitsLocked)
            {
                var res = _maxResolution != Resolution.Any ? _maxResolution.ToString() : "Any";
                var size = _maxFileSize > 0 ? $"{_maxFileSize} MB" : "Any";
                return $"Locked to {res} / {size}";
            }

            var parts = new List<string>();
            if (_maxResolution != Resolution.Any) parts.Add($"Max {_maxResolution}");
            if (_maxFileSize > 0) parts.Add($"{_maxFileSize} MB");
            return string.Join(", ", parts);
        }
    }

    /// <summary>
    /// True if the user has set any non-default download options,
    /// excluding convert when it's locked to preferred formats
    /// and limits when locked to enforced restrictions.
    /// </summary>
    private bool HasNonDefaultOptions =>
        (_segmentEnabled && SegmentHasValues) ||
        (_cropEnabled && CropHasValues) ||
        (!_alwaysConvert && ConvertHasValues) ||
        (!_limitsLocked && LimitsHasValues);

    private bool _lastNotifiedHasOptions;

    private async Task NotifyOptionsChanged()
    {
        var current = HasNonDefaultOptions;
        if (current != _lastNotifiedHasOptions)
        {
            _lastNotifiedHasOptions = current;
            await HasOptionsChanged.InvokeAsync(current);
        }
    }

    private void OnConvertValueChanged()
    {
        // Clear warned state if all convert values are back to default
        if (_convertWarned && !ConvertHasValues)
        {
            _convertWarned = false;
            _convertFlashing = false;
        }
    }

    private void OnLimitsValueChanged()
    {
        // Clear warned state if all limits values are back to default
        if (_limitsWarned && !LimitsHasValues)
        {
            _limitsWarned = false;
            _limitsFlashing = false;
        }
    }

    protected override void OnInitialized()
    {
        State.OnStateChanged += OnStateChanged;

        // Load segment mode from settings
        _segmentEndMode = Settings.Appearance.SegmentMode;

        // Apply "always convert to preferred" setting
        _alwaysConvert = Settings.Processing.AlwaysConvertToPreferred;
        if (_alwaysConvert)
        {
            _convertVideo = Settings.Processing.PreferredVideoFormat;
            _convertAudio = Settings.Processing.PreferredAudioFormat;
        }

        // Apply enforced restrictions
        if (Settings.Restrictions.EnforceRestrictions)
        {
            _limitsLocked = true;
            _maxResolution = Settings.Restrictions.MaxResolution;
            _maxFileSize = Settings.Restrictions.MaxFileSizeMb;
            if (LimitsHasValues) _limitsExpanded = true;
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        await NotifyOptionsChanged();
    }

    private void OnStateChanged()
    {
        InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        State.OnStateChanged -= OnStateChanged;
    }

    /// <summary>
    /// Resets all download options to defaults, except those locked to settings.
    /// </summary>
    public void ResetOptions()
    {
        // Segment
        _segmentStart = null;
        _segmentEnd = null;
        _segmentEnabled = false;
        _segmentExpanded = false;

        // Crop
        _cropTop = null;
        _cropBottom = null;
        _cropLeft = null;
        _cropRight = null;
        _cropEnabled = false;
        _cropExpanded = false;

        // Convert — only reset if not locked to preferred formats
        if (!_alwaysConvert)
        {
            _convertVideo = VideoFormat.Unspecified;
            _convertAudio = AudioFormat.Unspecified;
            _convertExpanded = false;
        }

        // Limits — only reset if not enforced by restrictions
        if (!_limitsLocked)
        {
            _maxResolution = Resolution.Any;
            _maxFileSize = 0;
            _limitsExpanded = false;
        }

        _convertFlashing = false;
        _limitsFlashing = false;
        _convertWarned = false;
        _limitsWarned = false;
        StateHasChanged();
    }

    /// <summary>
    /// Called when the URL input changes. Resets segment/crop and flashes
    /// a warning on convert/limits if they have non-default, non-locked values.
    /// </summary>
    public async Task OnUrlChangedAsync()
    {
        // Reset segment and crop (media-specific options)
        _segmentStart = null;
        _segmentEnd = null;
        _segmentEnabled = false;
        _segmentExpanded = false;

        _cropTop = null;
        _cropBottom = null;
        _cropLeft = null;
        _cropRight = null;
        _cropEnabled = false;
        _cropExpanded = false;

        // Flash convert if it has user-set values (not locked)
        if (!_alwaysConvert && ConvertHasValues)
        {
            _convertFlashing = true;
        }

        // Flash limits if it has user-set values (not locked)
        if (!_limitsLocked && LimitsHasValues)
        {
            _limitsFlashing = true;
        }

        StateHasChanged();

        // Stop flashing after the animation completes and leave indicator red
        if (_convertFlashing || _limitsFlashing)
        {
            await Task.Delay(1500);
            if (_convertFlashing) _convertWarned = true;
            if (_limitsFlashing) _limitsWarned = true;
            _convertFlashing = false;
            _limitsFlashing = false;
            StateHasChanged();
        }
    }

    private string FormatSelectionText
    {
        get
        {
            if (SelectedPair is null) return string.Empty;

            var video = SelectedPair.VideoFormat;
            var audio = SelectedPair.AudioFormat;

            if (video is not null && video.StreamKind == StreamKind.AudioAndVideo)
                return video.Format ?? FormatDescriptionFallback(video);

            if (video is not null && audio is not null)
            {
                var videoText = video.Format ?? FormatDescriptionFallback(video);
                var audioText = audio.Format ?? FormatDescriptionFallback(audio);
                return $"{videoText} + {audioText}";
            }

            if (video is not null)
                return video.Format ?? FormatDescriptionFallback(video);

            if (audio is not null)
                return audio.Format ?? FormatDescriptionFallback(audio);

            return string.Empty;
        }
    }

    private static string FormatDescriptionFallback(FormatInfo format)
    {
        var id = format.FormatId;
        if (format.Width.HasValue && format.Height.HasValue)
            return $"{id} - {format.Width}x{format.Height} ({format.Height}p)";
        if (format.StreamKind == StreamKind.Audio)
        {
            var note = format.FormatNote ?? format.AudioCodec ?? "audio";
            return $"{id} - audio only ({note})";
        }
        return id;
    }

    private DownloadRequest BuildRequest()
    {
        int[]? crops = null;
        if (_cropEnabled && CropHasValues)
            crops = [_cropTop ?? 0, _cropBottom ?? 0, _cropLeft ?? 0, _cropRight ?? 0];

        // Calculate segment duration based on mode (only if segment is enabled)
        TimeSpan? segStart = null;
        TimeSpan? segDuration = null;
        if (_segmentEnabled && _segmentStart.HasValue && _segmentEnd.HasValue)
        {
            segStart = _segmentStart;
            segDuration = _segmentEndMode == SegmentMode.Duration
                ? _segmentEnd
                : _segmentEnd - _segmentStart;

            // Final safety: clamp to media duration if known
            var maxDuration = EffectiveDuration;
            if (maxDuration.HasValue)
            {
                if (segStart.Value >= maxDuration.Value)
                    segStart = maxDuration.Value - TimeSpan.FromSeconds(1);
                if (segStart.Value < TimeSpan.Zero)
                    segStart = TimeSpan.Zero;
                if (segStart.Value + segDuration.Value > maxDuration.Value)
                    segDuration = maxDuration.Value - segStart.Value;
            }

            // Ensure duration is at least 1s
            if (segDuration.Value < TimeSpan.FromSeconds(1))
                segDuration = TimeSpan.FromSeconds(1);
        }
        else if (_segmentEnabled && _segmentStart.HasValue)
        {
            segStart = _segmentStart;

            // Clamp start if it exceeds duration
            var maxDuration = EffectiveDuration;
            if (maxDuration.HasValue && segStart.Value >= maxDuration.Value)
            {
                segStart = maxDuration.Value - TimeSpan.FromSeconds(1);
                if (segStart.Value < TimeSpan.Zero) segStart = TimeSpan.Zero;
            }
        }

        return new DownloadRequest
        {
            SegmentStart = segStart,
            SegmentDuration = segDuration,
            CropValues = crops,
            ConvertVideo = _convertVideo != VideoFormat.Unspecified ? _convertVideo : null,
            ConvertAudio = _convertAudio != AudioFormat.Unspecified ? _convertAudio : null,
            MaxResolutionPixels = ShowDownloadSelected ? 0 : _maxResolution switch
            {
                Resolution.Sd => 480,
                Resolution.Hd720 => 720,
                Resolution.Hd1080 => 1080,
                Resolution.Uhd2160 => 2160,
                _ => 0
            },
            MaxFileSizeMb = ShowDownloadSelected ? 0 : _maxFileSize
        };
    }

    private async Task OnClickDownloadVideo()
    {
