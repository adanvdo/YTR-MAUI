    /// <summary>
    /// Gets the effective media duration from the selected format or the metadata parameter.
    /// </summary>
    private TimeSpan? EffectiveDuration => SelectedPair?.Duration ?? MediaDuration;

    private void OnSegmentStartChanged(TimeSpan? value)
    {
        var maxDuration = EffectiveDuration;

        if (value.HasValue && maxDuration.HasValue)
        {
            // Don't allow start >= duration - 1s
            var maxStart = maxDuration.Value - TimeSpan.FromSeconds(1);
            if (maxStart < TimeSpan.Zero) maxStart = TimeSpan.Zero;
            if (value.Value > maxStart)
                value = maxStart;
        }

        _segmentStart = value;

        // Always ensure end is at least 1s after start (or 1s in duration mode)
        if (value.HasValue)
        {
            var minEnd = _segmentEndMode == SegmentMode.Duration
                ? TimeSpan.FromSeconds(1)
                : value.Value + TimeSpan.FromSeconds(1);

            if (!_segmentEnd.HasValue || _segmentEnd.Value < minEnd)
            {
                // Clamp to max duration if known
                if (maxDuration.HasValue && minEnd > maxDuration.Value)
                    minEnd = maxDuration.Value;
                _segmentEnd = minEnd;
            }
        }
    }

    private void OnSegmentEndChanged(TimeSpan? value)
    {
        var maxDuration = EffectiveDuration;

        // If cleared (null) but we have a start time, enforce minimum
        if (!value.HasValue && _segmentStart.HasValue)
        {
            var minEnd = _segmentEndMode == SegmentMode.Duration
                ? TimeSpan.FromSeconds(1)
                : _segmentStart.Value + TimeSpan.FromSeconds(1);

            if (maxDuration.HasValue && minEnd > maxDuration.Value)
                minEnd = maxDuration.Value;

            _segmentEnd = minEnd;
            return;
        }

        if (value.HasValue)
        {
            // Minimum end: at least 1s after start (or 1s in duration mode)
            var minEnd = _segmentEndMode == SegmentMode.Duration
                ? TimeSpan.FromSeconds(1)
                : (_segmentStart ?? TimeSpan.Zero) + TimeSpan.FromSeconds(1);

            if (value.Value < minEnd)
                value = minEnd;

            // Clamp to media duration if known
            if (maxDuration.HasValue)
            {
                if (_segmentEndMode == SegmentMode.Duration)
                {
                    var maxAllowed = _segmentStart.HasValue
                        ? maxDuration.Value - _segmentStart.Value
                        : maxDuration.Value;
                    if (maxAllowed < TimeSpan.FromSeconds(1)) maxAllowed = TimeSpan.FromSeconds(1);
                    if (value.Value > maxAllowed)
                        value = maxAllowed;
                }
                else
                {
                    if (value.Value > maxDuration.Value)
                        value = maxDuration.Value;
                }
            }
        }

        _segmentEnd = value;
    }

    private async Task OpenCropTool()
    {
        var videoFormat = SelectedPair?.VideoFormat;
        if (videoFormat is null || string.IsNullOrEmpty(_thumbnailUrl)) return;

        var parameters = new DialogParameters<CropTool>
        {
            { x => x.ThumbnailUrl, _thumbnailUrl },
            { x => x.VideoWidth, videoFormat.Width ?? 1920 },
            { x => x.VideoHeight, videoFormat.Height ?? 1080 }
        };

        var options = new DialogOptions { MaxWidth = MaxWidth.Medium, FullWidth = true };
        var dialog = await DialogService.ShowAsync<CropTool>("Crop Video", parameters, options);
        var result = await dialog.Result;

        if (result is not null && !result.Canceled && result.Data is int[] crops && crops.Length == 4)
        {
            _cropTop = crops[0] > 0 ? crops[0] : null;
            _cropBottom = crops[1] > 0 ? crops[1] : null;
            _cropLeft = crops[2] > 0 ? crops[2] : null;
            _cropRight = crops[3] > 0 ? crops[3] : null;
            _cropEnabled = true;
            _cropExpanded = true;
        }
    }
