@* Visual crop tool: draw a rectangle on the thumbnail to calculate crop values *@
@inject IJSRuntime JS

<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">Crop Video</MudText>
    </TitleContent>
    <DialogContent>
        <MudStack Spacing="2">
            <MudText Typo="Typo.caption" Color="Color.Tertiary">
                Draw a rectangle on the image to define the visible area. The crop values will be calculated based on the selected video resolution (@VideoWidth x @VideoHeight).
            </MudText>

            <div class="crop-container" @ref="_containerRef"
                 @onpointerdown="OnPointerDown" @onpointermove="OnPointerMove" @onpointerup="OnPointerUp"
                 style="position:relative; display:inline-block; user-select:none; cursor:crosshair; touch-action:none;">
                <img src="@ThumbnailUrl" @ref="_imgRef"
                     style="display:block; max-width:100%; height:auto; pointer-events:none;" />
                @if (_isDragging || _hasSelection)
                {
                    <div class="crop-overlay" style="@OverlayStyle"></div>
                    <div class="crop-selection" style="@SelectionStyle"></div>
                }
            </div>

            @if (_hasSelection)
            {
                <MudGrid>
                    <MudItem xs="3"><MudText Typo="Typo.caption">Top: @_cropTop px</MudText></MudItem>
                    <MudItem xs="3"><MudText Typo="Typo.caption">Bottom: @_cropBottom px</MudText></MudItem>
                    <MudItem xs="3"><MudText Typo="Typo.caption">Left: @_cropLeft px</MudText></MudItem>
                    <MudItem xs="3"><MudText Typo="Typo.caption">Right: @_cropRight px</MudText></MudItem>
                </MudGrid>
            }
        </MudStack>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Cancel</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="Apply" Disabled="!_hasSelection">
            Apply Crop
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] private IMudDialogInstance? MudDialog { get; set; }

    [Parameter] public string ThumbnailUrl { get; set; } = string.Empty;
    [Parameter] public int VideoWidth { get; set; }
    [Parameter] public int VideoHeight { get; set; }

    private ElementReference _containerRef;
    private ElementReference _imgRef;
    private bool _isDragging;
    private bool _hasSelection;

    // Actual displayed size of the container (fetched via JS)
    private double _containerWidth;
    private double _containerHeight;

    // Start and current positions as percentages of the container (0-100)
    private double _startXPct, _startYPct;
    private double _currentXPct, _currentYPct;

    // Calculated crop values in video pixels
    private int _cropTop, _cropBottom, _cropLeft, _cropRight;

    // Selection rectangle as percentages of the displayed image
    private double SelLeft => Math.Min(_startXPct, _currentXPct);
    private double SelTop => Math.Min(_startYPct, _currentYPct);
    private double SelWidth => Math.Abs(_currentXPct - _startXPct);
    private double SelHeight => Math.Abs(_currentYPct - _startYPct);

    private string SelectionStyle =>
        $"position:absolute; left:{SelLeft:F2}%; top:{SelTop:F2}%; width:{SelWidth:F2}%; height:{SelHeight:F2}%; " +
        "border: 2px solid #7C4DFF; background: rgba(124, 77, 255, 0.15); pointer-events:none; box-sizing:border-box;";

    private string OverlayStyle =>
        "position:absolute; inset:0; background: rgba(0,0,0,0.5); pointer-events:none; " +
        $"clip-path: polygon(0% 0%, 100% 0%, 100% 100%, 0% 100%, 0% 0%, " +
        $"{SelLeft:F2}% {SelTop:F2}%, {SelLeft:F2}% {(SelTop + SelHeight):F2}%, " +
        $"{(SelLeft + SelWidth):F2}% {(SelTop + SelHeight):F2}%, {(SelLeft + SelWidth):F2}% {SelTop:F2}%, {SelLeft:F2}% {SelTop:F2}%);";

    private async Task OnPointerDown(PointerEventArgs e)
    {
        // Get the actual rendered size of the container
        var bounds = await JS.InvokeAsync<ElementBounds>("cropToolInterop.getElementBounds", _containerRef);
        if (bounds is null) return;

        _containerWidth = bounds.Width;
        _containerHeight = bounds.Height;

        _isDragging = true;
        _hasSelection = false;

        // OffsetX/OffsetY is relative to the target element (the container div)
        // because pointer-events:none on the img ensures the container receives events
        var pctX = Math.Clamp(e.OffsetX / _containerWidth * 100, 0, 100);
        var pctY = Math.Clamp(e.OffsetY / _containerHeight * 100, 0, 100);

        _startXPct = pctX;
        _startYPct = pctY;
        _currentXPct = pctX;
        _currentYPct = pctY;
    }

    private void OnPointerMove(PointerEventArgs e)
    {
        if (!_isDragging || _containerWidth <= 0 || _containerHeight <= 0) return;

        var pctX = Math.Clamp(e.OffsetX / _containerWidth * 100, 0, 100);
        var pctY = Math.Clamp(e.OffsetY / _containerHeight * 100, 0, 100);

        _currentXPct = pctX;
        _currentYPct = pctY;
    }

    private void OnPointerUp(PointerEventArgs e)
    {
        if (!_isDragging) return;
        _isDragging = false;

        if (SelWidth > 1 && SelHeight > 1)
        {
            _hasSelection = true;
            CalculateCropValues();
        }
    }

    private void CalculateCropValues()
    {
        // The selection is drawn as a percentage of the displayed image.
        // The displayed image fills the container width and scales height proportionally.
        // We need to map the selection % to video pixel coordinates.
        //
        // The displayed image has the same aspect ratio as the thumbnail (usually 16:9).
        // The video may have a different resolution but we map the selection rectangle
        // directly as a proportion of the video dimensions — the selection represents
        // the KEEP area, so crop values = pixels removed from each edge.

        double selLeftPct = SelLeft / 100.0;
        double selTopPct = SelTop / 100.0;
        double selRightPct = (SelLeft + SelWidth) / 100.0;
        double selBottomPct = (SelTop + SelHeight) / 100.0;

        // Convert percentages to video pixel crop (pixels removed from each edge)
        _cropLeft = (int)Math.Round(selLeftPct * VideoWidth);
        _cropTop = (int)Math.Round(selTopPct * VideoHeight);
        _cropRight = (int)Math.Round((1.0 - selRightPct) * VideoWidth);
        _cropBottom = (int)Math.Round((1.0 - selBottomPct) * VideoHeight);

        // Clamp to valid range
        _cropLeft = Math.Max(0, _cropLeft);
        _cropTop = Math.Max(0, _cropTop);
        _cropRight = Math.Max(0, _cropRight);
        _cropBottom = Math.Max(0, _cropBottom);
    }

    private void Apply()
    {
        var result = new int[] { _cropTop, _cropBottom, _cropLeft, _cropRight };
        MudDialog?.Close(DialogResult.Ok(result));
    }

    private void Cancel() => MudDialog?.Cancel();

    private record ElementBounds(double Width, double Height, double Left, double Top);
}
