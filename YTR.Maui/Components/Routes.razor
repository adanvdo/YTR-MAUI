<Router AppAssembly="typeof(MauiProgram).Assembly"
        AdditionalAssemblies="new[] { typeof(YTR.Web.Components.Pages.Home).Assembly }">
    <Found Context="routeData">
        <RouteView RouteData="routeData" DefaultLayout="typeof(YTR.Web.Components.Layout.MainLayout)" />
        <FocusOnNavigate RouteData="routeData" Selector="h1" />
    </Found>
    <NotFound>
        <LayoutView Layout="typeof(YTR.Web.Components.Layout.MainLayout)">
            <MudText Typo="Typo.h5">Page not found</MudText>
        </LayoutView>
    </NotFound>
</Router>
